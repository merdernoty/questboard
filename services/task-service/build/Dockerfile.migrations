# migrations
FROM golang:1.25.3-alpine AS migrations

WORKDIR /app

# Устанавливаем необходимые пакеты
RUN apk add --no-cache make

# Создаем директорию для бинарников
RUN mkdir -p /app/bin

# Копируем зависимости
COPY go.mod go.sum ./
RUN go mod download

ENV GOBIN=/app/bin
RUN go install github.com/pressly/goose/v3/cmd/goose@v3.26.0

# Копируем файлы для миграций
COPY tools/migrations ./tools/migrations
COPY Makefile ./
# Добавляем GO bin в PATH
ENV PATH="/app/bin:${PATH}"
